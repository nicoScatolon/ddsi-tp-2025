@startuml
!theme plain

package "Agregador" {
  [API REST] --> [UI Solicitudes]
  [API REST] --> [Agregación]
  [Agregación] --> [Modelo Agregador]
  [Modelo Agregador] --> [Fuentes Agregador]
  [Modelo Agregador] --> [Solicitudes]
}

package "Fuente De Datos Estática" {
  [API REST] --> [Principal]
  [Principal] --> [Fuentes Estática]
  [Principal] --> [Dataset]
}

package "Fuente De Datos Dinámica" {
  [API REST] --> [UI Editor]
  [API REST] --> [Modelo Dinámico]
  [Modelo Dinámico] --> [Fuentes Dinámicas]
  [Modelo Dinámico] --> [Solicitudes Dinámicas]
  [Modelo Dinámico] --> [Hechos y Solicitudes]
  [UI Editor] --> [UI Solicitudes Dinámicas]
}

package "Fuente De Datos Proxy" {
  [API REST] --> [Modelo Proxy]
  [Modelo Proxy] --> [Fuentes Proxy]
  [Modelo Proxy] --> [Servicio Externo]
}

' Relaciones entre sistemas
[Modelo Agregador] --> [API REST] : Protocolo MetaMapa
[API REST] --> [OAuth / Proveedor de Identidad]
@enduml
