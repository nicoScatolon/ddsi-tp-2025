@startuml
left to right direction
skinparam packageStyle rectangle


actor "Administrador" as Admin
actor "Visualizador" as Viewer
actor "Contribuyente" as Contributor

rectangle "Sistema de Gestión de Mapeos Colaborativos" {
    usecase "Crear colección" as CU1
    usecase "Importar hechos" as CU2
    usecase "Navegar hechos de una colección" as CU3
    usecase "Solicitar eliminación de hecho" as CU5
    usecase "Aceptar o rechazar solicitud de eliminación" as CU6
    usecase "Crear un hecho" as CU7
}

Admin --> CU1
Admin --> CU2
Admin --> CU6
Admin --> CU7
Viewer --> CU3
Contributor --> CU5
Contributor --> CU7



 Admin --|> Viewer
 Contributor--|> Viewer

@enduml

